# 静态资源基础路径：生产前端打包后由后端同源托管在 /admin/** 下
VITE_BASE=/admin/

# 接口地址：同源部署，/api/** 由后端（同进程）直接处理
VITE_GLOB_API_URL=/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式（hash 适配静态托管，无需后端路由兜底）
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
