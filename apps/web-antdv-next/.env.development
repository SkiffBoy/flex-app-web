# 端口号
VITE_PORT=5999

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
# auth/user/menu/admin 流程已全走真后端（8080），mock 服务器仅供 Vben 框架非 auth 演示数据
# spec §3.4：backend-mock 可保留给非 auth 接口；如纯后端联调可设 false 加速 dev 启动
VITE_NITRO_MOCK=true

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
